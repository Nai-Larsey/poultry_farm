generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id
  firstname     String?
  surname       String?
  email         String?      @unique
  emailVerified DateTime?    @map("email_verified")
  image         String?
  role          Role         @default(OWNER)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  name          String?
  phoneNumber   String?      @map("phone_number")
  accounts      Account[]
  sessions      Session[]
  memberships   FarmMember[]

  @@map("users")
}

model Account {
  id                String  @id
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Session {
  id           String   @id
  sessionToken String   @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@map("verification_tokens")
}

model Farm {
  id        Int          @id
  name      String
  location  String?
  capacity  Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  userId    String       @default("user_placeholder")
  members   FarmMember[]
  houses    House[]
  invitations Invitation[]

  @@map("farms")
}

model House {
  id                 Int      @id
  farmId             Int
  name               String
  capacity           Int
  currentTemperature Decimal? @db.Decimal(5, 2)
  currentHumidity    Decimal? @db.Decimal(5, 2)
  userId             String   @default("user_placeholder")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  batches            Batch[]
  farm               Farm     @relation(fields: [farmId], references: [id])

  @@map("houses")
}

model Batch {
  id            Int             @id
  status        String          @default("active")
  arrivalDate   DateTime
  breedType     String
  createdAt     DateTime        @default(now())
  currentCount  Int
  houseId       Int
  initialCount  Int
  updatedAt     DateTime        @updatedAt
  userId        String          @default("user_placeholder")
  house         House           @relation(fields: [houseId], references: [id])
  feedingLogs   FeedingLog[]
  eggProduction EggProduction[]
  healthRecords HealthRecord[]
  mortality     Mortality[]
  weightRecords WeightRecord[]

  @@map("batches")
}

model Inventory {
  id          Int          @id
  itemName    String
  stockLevel  Decimal      @db.Decimal(10, 2)
  unit        String
  category    String?
  userId      String       @default("user_placeholder")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  feedingLogs FeedingLog[]

  @@map("inventory")
}

model FeedingLog {
  id             Int        @id
  batchId        Int?       @map("batch_id")
  feedTypeId     Int?       @map("feed_type_id")
  amountConsumed Decimal    @map("amount_consumed") @db.Decimal(10, 2)
  logDate        DateTime   @default(now()) @map("log_date")
  userId         String?    @map("user_id")
  batch          Batch?     @relation(fields: [batchId], references: [id])
  inventory      Inventory? @relation(fields: [feedTypeId], references: [id])

  @@map("daily_feeding_logs")
}

model HealthRecord {
  id          Int      @id
  batchId     Int?     @map("batch_id")
  recordType  String?  @map("record_type") @db.VarChar(50)
  description String?
  recordDate  DateTime @default(now()) @map("record_date") @db.Date
  batch       Batch?   @relation(fields: [batchId], references: [id])

  @@map("health_records")
}

model EggProduction {
  id            Int      @id
  batchId       Int
  eggsCollected Int
  damagedEggs   Int      @default(0)
  crackedEggs   Int      @default(0)
  logDate       DateTime
  userId        String   @default("user_placeholder")
  createdAt     DateTime @default(now())
  batch         Batch    @relation(fields: [batchId], references: [id])

  @@map("egg_production")
}

model Mortality {
  id          Int      @id
  batchId     Int
  count       Int
  reason      String?
  logDate     DateTime
  userId      String   @default("user_placeholder")
  createdAt   DateTime @default(now())
  category    String?
  subCategory String?  @map("sub_category")
  batch       Batch    @relation(fields: [batchId], references: [id])

  @@map("mortality")
}

model WeightRecord {
  id            Int      @id
  batchId       Int
  averageWeight Decimal  @db.Decimal(10, 3)
  logDate       DateTime
  userId        String   @default("user_placeholder")
  createdAt     DateTime @default(now())
  batch         Batch    @relation(fields: [batchId], references: [id])

  @@map("weight_records")
}

model Sale {
  id           Int        @id
  customerName String?
  totalAmount  Decimal    @db.Decimal(10, 2)
  saleDate     DateTime   @default(now()) @map("saleDate")
  status       String     @default("completed")
  userId       String     @default("user_placeholder")
  createdAt    DateTime   @default(now())
  items        SaleItem[]

  @@map("sales")
}

model SaleItem {
  id          Int     @id
  saleId      Int
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  sale        Sale    @relation(fields: [saleId], references: [id])

  @@map("sale_items")
}

model FarmMember {
  id        Int      @id
  farmId    Int
  userId    String
  role      Role     @default(WORKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("farm_members")
}

model Invitation {
  id          Int      @id
  email       String?
  phoneNumber String?  @map("phone_number")
  farmId      Int      @map("farm_id")
  role        Role     @default(WORKER)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  farm        Farm     @relation(fields: [farmId], references: [id])

  @@map("invitations")
}

enum Role {
  OWNER
  MANAGER
  WORKER
}
